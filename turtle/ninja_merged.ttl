wd:Q6884757 a crm:E22_Human-Made_Object,
        edm:ProvidedCHO ;
    dct:description "Despite depictions as shoes for walking on water, the design more plausibly centred on a wooden platform meant to be sat on rather than stood on, functioning as a buoyancy aid rather than footwear.",
        "Per the Bansenshūkai ninja of the Fujibayashi family reportedly used this water-flotation device." ;
    dct:relation wd:Q539067,
        wd:Q9402 ;
    owl:sameAs dbr:Mizugumo ;
    schema:name "Mizugumo" .

wd:Q7510141 a schema:Event ;
    dct:date "1562"^^xsd:gYear ;
    dct:description "Matsudaira Motoyasu's forces took hostages to trade for his own family then held by the Imagawa clan." ;
    dct:relation wd:Q539067 ;
    dct:spatial wd:Q11358375 ;
    crm:P11_had_participant wd:Q171977,
        wd:Q316952,
        wd:Q4352873 ;
    owl:sameAs dbr:Siege_of_Kaminogō_Castle ;
    schema:name "Siege of Kaminogō Castle" .

wd:Q806956 a edm:ProvidedCHO,
        schema:Book ;
    dct:description "Compiled in 1676, after the Sengoku-period height of ninja activity had passed and during a long peace under Tokugawa rule; its compiler was not a contemporary of the practices it records but drew on earlier oral and written tradition.",
        "Survives in two main manuscript traditions: a Kōga version (22 chapters in 10+1 volumes) and an Iga version (22 chapters in 12+4 volumes).",
        "Translated into English as \"The Book of Ninja\" by Antony Cummins and Yoshie Minami (2013)." ;
    dct:subject wd:Q539067 ;
    owl:sameAs dbr:Bansenshūkai ;
    schema:author "Fujibayashi Yasutake" ;
    schema:name "Bansenshūkai" .


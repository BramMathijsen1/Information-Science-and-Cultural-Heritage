wd:Q9402 a skos:Concept ;
    dct:description "Defined more by skillset and function than by social rank or class; the identity could be adopted situationally rather than marking a fixed separate caste, and historical samurai are recorded taking on ninja roles." ;
    owl:sameAs dbr:Ninja ;
    skos:related wd:Q539067 ;
    schema:name "Ninja" .

wd:Q539067 a skos:Concept ;
    dct:description "Not a single unified martial art but a collective term for numerous distinct schools (ryūha), often family-based, whose techniques were historically transmitted primarily through oral instruction rather than a standardized curriculum." ;
    owl:sameAs dbr:Ninjutsu ;
    schema:name "Ninjutsu" .


@prefix crm: <http://www.cidoc-crm.org/cidoc-crm/> .
@prefix dbr: <http://dbpedia.org/resource/> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix eac-cpf: <http://archivi.ibc.regione.emilia-romagna.it/ontology/eac-cpf/> .
@prefix edm: <http://www.europeana.eu/schemas/edm/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix ninja: <http://example.org/ninja-ontology#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema: <https://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix viaf: <https://viaf.org/viaf/> .
@prefix wd: <http://www.wikidata.org/entity/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ninja:embodiesArchetype a owl:ObjectProperty ;
    rdfs:label "embodies archetype"@en ;
    rdfs:comment "A real person who became the cultural archetype/exemplar of a legendary identity."@en ;
    rdfs:domain crm:E21_Person ;
    rdfs:range skos:Concept .

ninja:exemplifiesDiscipline a owl:ObjectProperty ;
    rdfs:label "exemplifies discipline"@en ;
    rdfs:comment "This is not nesseceraly a bsubject but it exemplifies a dicipline."@en ;
    rdfs:domain schema:Event ;
    rdfs:range skos:Concept .

ninja:isAssociatedWithArchetype a owl:ObjectProperty ;
    rdfs:label "is associated with archetype"@en ;
    rdfs:comment "A physical object's association with a legendary identity/archetype (Mizugumo, the water-crossing device, with the Ninja archetype), rather than with a real agent who could formally 'use' it, and its also not a class. There exists Concept to concept, but no property fits an Object-to-Concept subject"@en ;
    rdfs:domain crm:E22_Human-Made_Object ;
    rdfs:range skos:Concept .

ninja:isToolOfDiscipline a owl:ObjectProperty ;
    rdfs:label "is tool of discipline"@en ;
    rdfs:comment "This is specifically a tool, so thats why it got his own relation"@en ;
    rdfs:domain crm:E22_Human-Made_Object ;
    rdfs:range skos:Concept .

ninja:isVassalOf a owl:ObjectProperty ;
    rdfs:label "is vassal of"@en ;
    rdfs:comment "A feudal-era person's ongoing service obligation to their lord."@en ;
    rdfs:domain crm:E21_Person ;
    rdfs:range crm:E21_Person ;
    rdfs:subPropertyOf eac-cpf:cpfRelation .

ninja:preservesKnowledgeOf a owl:ObjectProperty ;
    rdfs:label "preserves knowledge of"@en ;
    rdfs:comment "A written work compiled specifically to safeguard a school's practices for the future, distinct from merely documenting or being about them. dct:subject/crm:P70_documents both describe a neutral act of recording; this is a stronger, intentional claim of preservation against loss. CIDOC-CRM's own literature notes it 'lacks support for higher-level conceptual structures associated with patterned forms of (intangible) heritage: recurring activities, practices, collective behavior, tradition' — no property in CRM, schema.org, DCT, or RDA models this act specifically."@en ;
    rdfs:domain schema:Book ;
    rdfs:range crm:E74_Group .

wd:Q42564798 a schema:VideoGame ;
    dct:issued "2020"^^xsd:gYear ;
    dct:subject wd:Q9402 ;
    owl:sameAs dbr:Ghost_of_Tsushima ;
    foaf:depicts wd:Q9402 ;
    foaf:maker wd:Q916714 ;
    schema:genre "action-adventure" ;
    schema:name "Ghost of Tsushima" ;
    schema:publisher "Sony Interactive Entertainment" .

wd:Q4306401 a schema:Museum ;
    dct:description "Located near Iga Ueno Castle; includes a model ninja village open to tours." ;
    dct:subject wd:Q9402 ;
    crm:P50i_is_current_keeper_of wd:Q860340 ;
    owl:sameAs dbr:Ninja_Museum_of_Igaryu ;
    schema:containedInPlace wd:Q128196 ;
    schema:foundingDate "1964"^^xsd:gYear ;
    schema:name "Ninja Museum of Igaryu",
        "伊賀流忍者博物館"@ja .

wd:Q6884757 a crm:E22_Human-Made_Object,
        edm:ProvidedCHO ;
    ninja:isAssociatedWithArchetype wd:Q9402 ;
    ninja:isToolOfDiscipline wd:Q539067 ;
    dct:description "Despite depictions as shoes for walking on water, the design more plausibly centred on a wooden platform meant to be sat on rather than stood on, functioning as a buoyancy aid rather than footwear.",
        "Per the Bansenshūkai ninja of the Fujibayashi family reportedly used this water-flotation device." ;
    crm:P45_consists_of "Wood" ;
    owl:sameAs dbr:Mizugumo ;
    schema:name "Mizugumo",
        "水蜘蛛"@ja .

wd:Q7510141 a schema:Event ;
    ninja:exemplifiesDiscipline wd:Q539067 ;
    dct:date "1562"^^xsd:gYear ;
    dct:description "Matsudaira Motoyasu's forces took hostages to trade for his own family then held by the Imagawa clan." ;
    crm:P11_had_participant wd:Q171977,
        wd:Q316952,
        wd:Q4352873 ;
    owl:sameAs dbr:Siege_of_Kaminogō_Castle ;
    schema:location wd:Q11358375 ;
    schema:name "Siege of Kaminogō Castle" .

wd:Q806956 a edm:ProvidedCHO,
        schema:Book ;
    ninja:preservesKnowledgeOf wd:Q3275530 ;
    dct:description "Compiled in 1676, after the Sengoku-period height of ninja activity had passed and during a long peace under Tokugawa rule; its compiler was not a contemporary of the practices it records but drew on earlier oral and written tradition.",
        "Survives in two main manuscript traditions: a Kōga version (22 chapters in 10+1 volumes) and an Iga version (22 chapters in 12+4 volumes).",
        "Translated into English as \"The Book of Ninja\" by Antony Cummins and Yoshie Minami (2013)." ;
    dct:subject wd:Q539067 ;
    owl:sameAs dbr:Bansenshūkai ;
    schema:author "Fujibayashi Yasutake" ;
    schema:name "Bansenshūkai",
        "万川集海"@ja .

wd:Q11358375 a schema:LandmarksOrHistoricalBuildings ;
    schema:containedInPlace wd:Q768158 ;
    schema:name "Kaminogō Castle" .

wd:Q316952 a crm:E21_Person,
        foaf:Person ;
    ninja:embodiesArchetype wd:Q9402 ;
    ninja:isVassalOf wd:Q171977 ;
    dct:description "Commanded the shogunate's yoriki officers and 200 civil officials after Ieyasu's move to the Kantō region.",
        "Retired as a Buddhist monk and founded Sainen-ji temple in Edo (now Shinjuku Tokyo) where he is buried." ;
    dct:isReplacedBy wd:Q4432157 ;
    crm:P107i_is_current_or_former_member_of wd:Q3275530 ;
    owl:sameAs dbr:Hattori_Hanzō,
        viaf:257979857 ;
    schema:birthPlace wd:Q768158 ;
    schema:homeLocation wd:Q1047128 ;
    schema:knowsAbout wd:Q539067 ;
    schema:name "Hattori Hanzō" .

wd:Q4352873 a crm:E21_Person,
        foaf:Person ;
    schema:name "Udono Nagateru" .

wd:Q4432157 a crm:E21_Person,
        foaf:Person ;
    schema:name "Hattori Masanari" .

wd:Q860340 a crm:E22_Human-Made_Object,
        edm:ProvidedCHO ;
    ninja:isAssociatedWithArchetype wd:Q9402 ;
    ninja:isToolOfDiscipline wd:Q539067 ;
    dct:description "Originally a stabbing/thrusting tool rather than a throwing weapon; the \"thrown ninja knife\" image comes from modern fiction." ;
    crm:P43_has_dimension "20-30 centimetre" ;
    crm:P45_consists_of "soft iron" ;
    owl:sameAs dbr:Kunai ;
    schema:name "Kunai" .

wd:Q916714 a foaf:Organization,
        schema:Corporation ;
    schema:name "Sucker Punch Productions" .

wd:Q1047128 a schema:AdministrativeArea,
        schema:Place ;
    dct:date "1871"^^xsd:gYear ;
    dct:description "Divided into 4 districts (郡) with about 197 villages before its abolition." ;
    dct:isReplacedBy wd:Q128196 ;
    owl:sameAs dbr:Iga_Province,
        <https://sws.geonames.org/11468270/>,
        viaf:252317211 ;
    schema:name "Iga Province" .

wd:Q128196 a schema:AdministrativeArea ;
    schema:name "Mie Prefecture" .

wd:Q171977 a crm:E21_Person,
        foaf:Person ;
    schema:name "Tokugawa Ieyasu" .

wd:Q3275530 a crm:E74_Group ;
    dct:date "1487"^^xsd:gYear ;
    dct:description "Historically associated above all with the Hattori clan and the Fujibayashi clan." ;
    owl:sameAs dbr:Iga-ryū ;
    schema:foundingLocation wd:Q1047128 ;
    schema:knowsAbout wd:Q539067 ;
    schema:name "Iga-ryū",
        "伊賀流"@ja .

wd:Q768158 a schema:AdministrativeArea ;
    schema:name "Mikawa Province" .

wd:Q9402 a skos:Concept ;
    dct:description "Defined more by skillset and function than by social rank or class; the identity could be adopted situationally rather than marking a fixed separate caste, and historical samurai are recorded taking on ninja roles." ;
    owl:sameAs dbr:Ninja ;
    skos:related wd:Q539067 ;
    schema:name "Ninja" .

wd:Q539067 a skos:Concept ;
    dct:description "Not a single unified martial art but a collective term for numerous distinct schools (ryūha), often family-based, whose techniques were historically transmitted primarily through oral instruction rather than a standardized curriculum." ;
    owl:sameAs dbr:Ninjutsu ;
    schema:name "Ninjutsu",
        "忍術"@ja .

